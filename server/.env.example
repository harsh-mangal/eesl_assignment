NODE_ENV=development
PORT=4001
DATABASE_URL="mysql://member_app:member_app_password@localhost:3307/member_services"
JWT_SECRET="replace-with-a-long-random-secret-at-least-32-characters"
JWT_EXPIRES_IN="7d"
CORS_ORIGINS="http://localhost:5173,http://localhost:8081"
PUBLIC_BASE_URL="http://localhost:4001"

# Use local storage while developing. Use cloudinary for stateless cloud hosting.
UPLOAD_PROVIDER="local"
UPLOAD_DIR="uploads"
MAX_UPLOAD_MB=5
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_FOLDER="member-services"

API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=500
AUTH_RATE_LIMIT_MAX=20
