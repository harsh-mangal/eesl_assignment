      "adaptiveIcon": {
        "backgroundColor": "#101828"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.memberservices.app"
    },
    "plugins": [
      "expo-asset",
      "expo-font"
    ]
  }
}
